# =========================================================================
# core-api environment. Copy to .env and fill in. .env is git-ignored.
# In production, inject these via your orchestrator / secret manager.
# =========================================================================

DEV_MODE=False
ENABLE_PERFORMANCE_LOGGER=True

# --- HTTP server ---
# HOST=0.0.0.0
# PORT=8000
SELF_HOST=api.aixii.com
SELF_PORT=8000

# --- Shared PostgreSQL cluster (one server for all services) ---
DB_USER=
DB_PASSWORD=
DB_HOST=your-postgres-host
DB_PORT=5432
# core-api OWNS these databases (main DB schema lives in db-contract):
# Two physical databases after the AIXII consolidation (aviation data + infra):
DB_AIXII_NAME=aixii
DB_SERVICE_NAME=service

# --- Shared Redis (cache + ARQ broker; MUST be the same Redis for all services) ---
REDIS_USER=
REDIS_USER_PASSWORD=
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# --- Service-to-service token (portal -> this API). Must equal portal CORE_API_TOKEN. ---
SERVICE_TOKEN=

# --- file-processor service (core-api forwards uploaded files here over HTTP) ---
FILE_PROCESSOR_URL=http://file-processor:8000
# must equal file-processor SERVICE_TOKEN
FILE_PROCESSOR_TOKEN=

# --- Power BI Embedded capacity control (Azure ARM; optional feature) ---
# Dedicated control service principal (NOT the embed SPN), provisioned by the azure setup script with a
# narrow read/suspend/resume role. Leave unset to keep the /capacity endpoints disabled (503).
# PBIE_CLIENT_SECRET is a bearer credential for the capacity — inject via secret manager, never commit.
PBIE_TENANT_ID=
PBIE_CLIENT_ID=
PBIE_CLIENT_SECRET=
PBIE_SUBSCRIPTION_ID=
PBIE_RESOURCE_GROUP=
PBIE_CAPACITY_NAME=

# --- API metadata / CORS (defaults applied if unset) ---
# API_TITLE=AIXII API Server
# API_VERSION=v1.0.5a
# API_ROOT_URL=/api/v1
# CORS_ORIGINS=*

# --- Microsoft Graph webhook validation (REQUIRED; same value as external-worker) ---
MS_WEBHOOK_SECRET=

# --- Migrations on startup (default off; run as a deliberate job instead) ---
# RUN_MIGRATIONS=false
# MIGRATE_DBS=aixii service
